{
  "expo": {
    "name": "TroyStack",
    "slug": "stack-tracker-pro",
    "version": "3.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "primaryColor": "#fbbf24",
    "scheme": [
      "stacktrackergold",
      "troystack"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stacktrackerpro.app",
      "buildNumber": "102",
      "requireFullScreen": false,
      "usesAppleSignIn": true,
      "appleTeamId": "3BKELS5FG9",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.stacktrackerpro.shared"
        ]
      },
      "infoPlist": {
        "CFBundleDisplayName": "Troy",
        "NSCameraUsageDescription": "TroyStack needs camera access to scan your precious metals purchase receipts using AI-powered OCR. Your photos are processed securely and never stored.",
        "NSPhotoLibraryUsageDescription": "TroyStack needs photo library access to scan your purchase receipts. Your photos are processed securely and never stored on our servers.",
        "NSPhotoLibraryAddUsageDescription": "TroyStack needs permission to save export files to your photo library for backup purposes.",
        "NSFaceIDUsageDescription": "TroyStack uses Face ID to securely protect your precious metals portfolio data with biometric authentication.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "mailto"
        ],
        "NSMicrophoneUsageDescription": "TroyStack uses the microphone to let you talk to Troy, your AI stack analyst. Audio is sent securely for transcription and is not stored.",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "processing",
          "remote-notification"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "background-fetch-prices"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:troystack.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1d2e"
      },
      "package": "com.stacktrackerpro.app",
      "versionCode": 4,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "TroyStack accesses your photos to scan precious metals purchase receipts. Your photos are processed securely and never stored.",
          "cameraPermission": "TroyStack uses the camera to scan purchase receipts using AI. Your photos are processed in memory and immediately discarded."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "TroyStack uses Face ID to securely protect your precious metals portfolio data."
        }
      ],
      [
        "react-native-cloud-storage",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#fbbf24"
        }
      ],
      "./plugins/withWidgetNativeModule.js",
      "@bacons/apple-targets"
    ],
    "extra": {
      "apiUrl": "https://api.stacktrackergold.com",
      "eas": {
        "projectId": "384c4e8d-a38b-4bb2-b954-0a77e2b226e8",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.stacktrackerpro.app.widget",
                  "targetName": "StackTrackerWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.stacktrackerpro.shared"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "privacy": "unlisted",
    "description": "Privacy-first precious metals portfolio tracker. Track your gold and silver holdings with AI-powered receipt scanning. Your data stays on your device - we can't access it.",
    "githubUrl": "https://github.com/kingleosgold/stack-tracker-pro",
    "owner": "kingleosgold",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/384c4e8d-a38b-4bb2-b954-0a77e2b226e8"
    }
  }
}
